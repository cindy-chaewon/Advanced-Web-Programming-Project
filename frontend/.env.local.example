# Hi-Five frontend env (예시 — 팀원이 .env.local로 복사 후 값 채우기)
#
# 사용법:
#   cp .env.local.example .env.local
#   값은 backend/.env 또는 카카오 디벨로퍼스 콘솔에서 가져오기

# 백엔드 API base URL
NEXT_PUBLIC_API_BASE=http://localhost:8000

# 카카오 REST API 키 (OAuth 인가 URL 만들 때 클라이언트가 사용)
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
NEXT_PUBLIC_KAKAO_CLIENT_ID=

# 카카오맵 JavaScript SDK 키 (브라우저에서 지도 그릴 때 사용)
# 같은 콘솔의 JavaScript 키
NEXT_PUBLIC_KAKAO_MAP_API_KEY=

# 카카오 OAuth redirect URI (백엔드와 동일하게 맞춤. 콘솔에도 등록 필요)
# 개발: http://localhost:8000/api/v1/auth/kakao/callback
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/kakao/callback
