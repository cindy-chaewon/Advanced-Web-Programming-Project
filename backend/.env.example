# ==========================================
# Hi-Five Backend Environment Variables
# 사용법: cp .env.example .env  → 값 채우기
# ==========================================

# === Application ===
APP_NAME=Hi-Five API
DEBUG=true
API_V1_PREFIX=/api/v1

# === Database (MySQL) ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mapweb

# === JWT ===
JWT_SECRET=change-this-to-a-strong-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# === CORS (쉼표 구분) ===
CORS_ORIGINS=http://localhost:3000

# === Kakao OAuth ===
# https://developers.kakao.com/
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/kakao/callback

# === Kakao Map API ===
# https://apis.map.kakao.com/
KAKAO_MAP_API_KEY=

# === Gemini AI ===
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# === File Upload ===
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880
