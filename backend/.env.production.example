# ==========================================
# Hi-Five Backend — 운영(Production) 환경 변수 예시
# 사용법: cp .env.production.example .env  → 실제 값 채우기
# ⚠️ 절대 커밋 금지. .env는 .gitignore에 포함되어 있음.
# ==========================================

# === Application ===
APP_NAME=Hi-Five API
# 운영에서는 반드시 false. SQL 에코 로그 끔, 자세한 트레이스 노출 방지.
DEBUG=false
API_V1_PREFIX=/api/v1

# === Database (MySQL) ===
# 운영 DB 호스트 (예: RDS 엔드포인트, 내부 DNS 등)
DB_HOST=
DB_PORT=3306
# 운영 전용 DB 계정 사용 권장 (개발용 mapweb/mapweb1234 그대로 쓰지 말 것)
DB_USER=
DB_PASSWORD=
DB_NAME=mapweb

# === JWT ===
# ⚠️ 반드시 충분히 긴 무작위 문자열로 교체 (`openssl rand -hex 32` 등). 개발 시크릿 재사용 금지.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# === CORS (쉼표 구분) ===
# 운영에서는 명시적인 프론트엔드 도메인만 허용. localhost 금지.
# 예: CORS_ORIGINS=https://hifive.example.com,https://www.hifive.example.com
CORS_ORIGINS=

# === Kakao OAuth ===
# Kakao Developers 콘솔에서 운영용 앱 키 발급 + Redirect URI 등록 필요.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
# 운영 도메인 기준 Redirect URI (Kakao 콘솔 등록값과 일치해야 함)
KAKAO_REDIRECT_URI=https://hifive.example.com/api/v1/auth/kakao/callback

# === Kakao Map API ===
KAKAO_MAP_API_KEY=

# === Gemini AI ===
# 운영 키는 개발 키와 분리 발급 권장. 분당 15 요청 제한 고려.
GEMINI_API_KEY=

# === File Upload ===
# 운영에서는 로컬 파일시스템 대신 S3/Cloud Storage로 이전 검토 (현재 로컬 저장).
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880
